{
  "name": "todo-backend",
  "version": "1.0.0",
  "private": true,
  "description": "REST API for the Todo desktop application",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:migrate": "node src/scripts/migrate.js",
    "test": "NODE_ENV=test jest --runInBand --detectOpenHandles --forceExit",
    "test:coverage": "NODE_ENV=test jest --runInBand --detectOpenHandles --forceExit --coverage",
    "lint": "eslint . --fix"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2"
  }
}
